# ─────────────────────────────────────────────
# NEXUS REFACTOR — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your keys.
# These are ONLY used for server-side API proxy routes.
# In "Live" mode, users provide their own API key (client-side).
# In "Demo" mode, the system uses mock responses (no API needed).

# Anthropic Claude API Key (optional — for server-side proxy)
ANTHROPIC_API_KEY=

# OpenAI API Key (optional — for server-side proxy)
OPENAI_API_KEY=
